#!name=Media Unlock Check
#!desc=Open https://media-check.shadowrocket/test in Safari to run the unlock check
#!homepage=https://github.com/folkss/shadowrocket-media-check

[Script]
media_unlock_check = type=http-request,pattern=^https?:\/\/media-check\.shadowrocket\/test(?:\?.*)?$,script-path=https://raw.githubusercontent.com/folkss/shadowrocket-media-check/main/media_unlock_check_sr.js,timeout=60,enable=true
